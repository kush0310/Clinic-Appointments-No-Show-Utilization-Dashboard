      <column caption='Hour Bucket' datatype='string' name='[Calculation_3435603862319106]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 10 THEN &quot;8-10&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 12 THEN &quot;10-12&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 14 THEN &quot;12-2&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 16 THEN &quot;2-4&quot;&#10;ELSE &quot;4-6&quot;&#10;END' />
      </column>
      <column caption='Day Name' datatype='string' name='[Calculation_3435603862384643]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;,[AppointmentDate])' />
      </column>
      <column caption='Is No Show' datatype='boolean' name='[Calculation_3435603862458372]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Status] = &quot;NoShow&quot;' />
      </column>
      <column caption='No Show % (Cell)' datatype='real' name='[Calculation_3435603862781957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([AppointmentID]) / &#10;WINDOW_SUM(COUNT([AppointmentID]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='No Show Rate (Heatmap)' datatype='real' name='[Calculation_3435603863564295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Status] = &quot;NoShow&quot; THEN 1 ELSE 0 END)&#10;/&#10;COUNT([AppointmentID])' />
      </column>
