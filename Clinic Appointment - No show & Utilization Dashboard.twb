    <worksheet name='HeatMap'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>No-Show Hotspots (Day × Hour)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='appointment_detail' name='federated.0hfcbeh1d1imry12aorwo0fp8kiq' />
          </datasources>
          <datasource-dependencies datasource='federated.0hfcbeh1d1imry12aorwo0fp8kiq'>
            <column caption='Appointment Date' datatype='date' name='[AppointmentDate]' role='dimension' type='ordinal' />
            <column caption='Appointment ID' datatype='integer' name='[AppointmentID]' role='dimension' type='ordinal' />
            <column caption='Hour Bucket' datatype='string' name='[Calculation_3435603862319106]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 10 THEN &quot;8-10&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 12 THEN &quot;10-12&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 14 THEN &quot;12-2&quot;&#10;ELSEIF DATEPART(&apos;hour&apos;,[StartTime]) &lt; 16 THEN &quot;2-4&quot;&#10;ELSE &quot;4-6&quot;&#10;END' />
            </column>
            <column caption='Day Name' datatype='string' name='[Calculation_3435603862384643]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;,[AppointmentDate])' />
            </column>
            <column caption='No Show Rate (Heatmap)' datatype='real' name='[Calculation_3435603863564295]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Status] = &quot;NoShow&quot; THEN 1 ELSE 0 END)&#10;/&#10;COUNT([AppointmentID])' />
            </column>
            <column aggregation='Hour' caption='Start Time' datatype='datetime' name='[StartTime]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_3435603862319106]' derivation='None' name='[none:Calculation_3435603862319106:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3435603862384643]' derivation='None' name='[none:Calculation_3435603862384643:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3435603863564295]' derivation='User' name='[usr:Calculation_3435603863564295:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0hfcbeh1d1imry12aorwo0fp8kiq].[none:Calculation_3435603862384643:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Monday&quot;</bucket>
              <bucket>&quot;Tuesday&quot;</bucket>
              <bucket>&quot;Wednesday&quot;</bucket>
              <bucket>&quot;Thursday&quot;</bucket>
              <bucket>&quot;Friday&quot;</bucket>
              <bucket>&quot;Saturday&quot;</bucket>
              <bucket>&quot;Sunday&quot;</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.0hfcbeh1d1imry12aorwo0fp8kiq].[usr:Calculation_3435603863564295:qk]' value='p0%' />
